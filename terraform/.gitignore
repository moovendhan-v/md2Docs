###############################################################################
# .gitignore for the terraform/ directory
###############################################################################

# State files — NEVER commit
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/

# Lock file (commit this if you want reproducible provider versions)
# .terraform.lock.hcl

# Real values — NEVER commit
terraform.tfvars
*.auto.tfvars

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan files (may contain secrets)
*.tfplan
