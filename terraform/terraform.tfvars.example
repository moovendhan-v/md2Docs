# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars should be in .gitignore — never commit it.

cloudflare_api_token   = "your-cloudflare-api-token"
cloudflare_account_id  = "your-cloudflare-account-id"

project_name       = "md-to-docs"
production_branch  = "main"

github_owner      = "your-github-username-or-org"
github_repo_name  = "md-to-docs"

node_version = "20"

# Leave all blank to skip custom domain setup
custom_domain             = ""
custom_domain_record_name = "@"
cloudflare_zone_id        = ""

# Extra subdomains (Optional)
md2docx_domain      = "" # e.g. "md2docx.cybertechmind.com"
md2docx_record_name = "" # e.g. "md2docx"

md2pdf_domain      = "" # e.g. "md2pdf.cybertechmind.com"
md2pdf_record_name = "" # e.g. "md2pdf"


# NOTE: R2 remote-state credentials are NOT set here anymore.
# Export them as environment variables before running deploy.sh:
#   export R2_ACCESS_KEY_ID="your-r2-access-key-id"
#   export R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
